---
const products = [
  {
    id: 1,
    name: "Paracetamol 500mg",
    category: "Analgésicos",
    price: "$12.990",
    image: "product1",
    badge: "Popular"
  },
  {
    id: 2,
    name: "Ibuprofeno 400mg",
    category: "Antiinflamatorios",
    price: "$15.990",
    image: "product2",
    badge: "Nuevo"
  },
  {
    id: 3,
    name: "Vitamina C 1000mg",
    category: "Vitaminas",
    price: "$18.990",
    image: "product3",
    badge: "Oferta"
  },
  {
    id: 4,
    name: "Protector Solar FPS 50",
    category: "Cuidado Personal",
    price: "$24.990",
    image: "product4",
    badge: null
  },
  {
    id: 5,
    name: "Termómetro Digital",
    category: "Equipos Médicos",
    price: "$19.990",
    image: "product5",
    badge: "Destacado"
  },
  {
    id: 6,
    name: "Alcohol Gel 500ml",
    category: "Higiene",
    price: "$8.990",
    image: "product6",
    badge: null
  }
];
---

<section class="products section" id="productos">
  <div class="container">
    <h2 class="section-title">Productos Recientes</h2>
    <div class="products-grid">
      {products.map((product) => (
        <article class="product-card">
          {product.badge && (
            <div class="product-badge">{product.badge}</div>
          )}
          <div class="product-image" data-product={product.image}>
            <div class="product-image-placeholder">
              <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
                <rect width="100" height="100" rx="8" fill="var(--color-bg-secondary)"/>
                <circle cx="50" cy="50" r="30" fill="white"/>
                <path d="M50 30V70M30 50H70" stroke="var(--color-primary)" stroke-width="4" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
          <div class="product-content">
            <span class="product-category">{product.category}</span>
            <h3 class="product-name">{product.name}</h3>
            <div class="product-footer">
              <span class="product-price">{product.price}</span>
              <button class="btn-add-cart">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path d="M3 3H5L7 13H17L19 5H7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="8" cy="17" r="1" fill="currentColor"/>
                  <circle cx="16" cy="17" r="1" fill="currentColor"/>
                </svg>
              </button>
            </div>
          </div>
        </article>
      ))}
    </div>
    <div class="products-cta">
      <a href="#contacto" class="btn btn-primary">Ver Todos los Productos</a>
    </div>
  </div>
</section>

<style>
  .products {
    background-color: white;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .product-card {
    position: relative;
    background-color: white;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    overflow: hidden;
    transition: var(--transition);
  }

  .product-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .product-badge {
    position: absolute;
    top: var(--spacing-sm);
    left: var(--spacing-sm);
    background-color: var(--color-warning);
    color: white;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--border-radius);
    font-size: var(--font-size-sm);
    font-weight: 600;
    z-index: 1;
  }

  .product-image {
    width: 100%;
    height: 250px;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .product-image[data-product="product1"] {
    background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  }

  .product-image[data-product="product2"] {
    background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
  }

  .product-image[data-product="product3"] {
    background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  }

  .product-image[data-product="product4"] {
    background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  }

  .product-image[data-product="product5"] {
    background: linear-gradient(135deg, #fce4ec 0%, #f8bbd0 100%);
  }

  .product-image[data-product="product6"] {
    background: linear-gradient(135deg, #e0f2f1 0%, #b2dfdb 100%);
  }

  .product-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-content {
    padding: var(--spacing-md);
  }

  .product-category {
    display: inline-block;
    color: var(--color-text-light);
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: var(--spacing-xs);
  }

  .product-name {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
  }

  .product-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .product-price {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-primary);
  }

  .btn-add-cart {
    background-color: var(--color-primary);
    color: white;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-add-cart:hover {
    background-color: var(--color-accent);
    transform: scale(1.1);
  }

  .products-cta {
    text-align: center;
  }

  @media (max-width: 768px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
