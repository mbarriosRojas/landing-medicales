      <div class="footer-section">
        <h4 class="footer-heading">Enlaces Rápidos</h4>
        <ul class="footer-links">
          <li><a href="#inicio">Inicio</a></li>
          <li><a href="#promociones">Promociones</a></li>
          <li><a href="#productos">Productos</a></li>
          <li><a href="#nosotros">Nosotros</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h4 class="footer-heading">Categorías</h4>
        <ul class="footer-links">
          <li><a href="#productos">Medicamentos</a></li>
          <li><a href="#productos">Vitaminas</a></li>
          <li><a href="#productos">Cuidado Personal</a></li>
          <li><a href="#productos">Primeros Auxilios</a></li>
          <li><a href="#productos">Equipos Médicos</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h4 class="footer-heading">Legal</h4>
        <ul class="footer-links">
          <li><a href="#">Términos y Condiciones</a></li>
          <li><a href="#">Política de Privacidad</a></li>
          <li><a href="#">Política de Cookies</a></li>
          <li><a href="#">Preguntas Frecuentes</a></li>
